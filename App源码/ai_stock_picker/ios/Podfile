platform :ios, '13.0'

# Ruby 3.4+ 兼容：File.exists? 已被移除，但 Flutter 3.0.0 的 podhelper 还在用
unless File.respond_to?(:exists?)
  class << File
    alias_method :exists?, :exist?
  end
end

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

# pre_install: 在所有 Pod 安装前设置 Swift 版本，修复 workmanager 等插件的 Swift 版本检测
pre_install do |installer|
  Pod::Installer::Xcode::TargetValidator.send(:define_method, :verify_swift_pods_swift_version) {}
end

target 'Runner' do
  use_frameworks!
  # 不启用 modular_headers，否则 Flutter/Flutter.h 找不到（module map 问题）
  # use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  # 为所有 Pod 目标添加 Flutter framework 搜索路径
  flutter_dir = File.join(File.dirname(File.realpath(__FILE__)), 'Flutter')
  # arm64 macOS runner 上的 Flutter engine 路径
  flutter_engine_dir = File.join(flutter_root, 'bin', 'cache', 'artifacts', 'engine', 'ios')
  
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['SWIFT_VERSION'] = '5.0'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      
      # FRAMEWORK_SEARCH_PATHS：让所有 Pod 都能找到 Flutter.framework
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] ||= ['$(inherited)']
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] += [
        flutter_dir,
        flutter_engine_dir,
        '${PODS_ROOT}/../Flutter',
        '${PODS_CONFIGURATION_BUILD_DIR}/Flutter'
      ]
      
      # HEADER_SEARCH_PATHS
      config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']
      config.build_settings['HEADER_SEARCH_PATHS'] += [
        "#{flutter_dir}/Flutter.framework/Headers",
        "#{flutter_engine_dir}/Flutter.framework/Headers"
      ]
    end
  end
end
