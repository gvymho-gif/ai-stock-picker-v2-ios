platform :ios, '13.0'

unless File.respond_to?(:exists?)
  class << File
    alias_method :exists?, :exist?
  end
end

ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end
  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

pre_install do |installer|
  Pod::Installer::Xcode::TargetValidator.send(:define_method, :verify_swift_pods_swift_version) {}
end

target 'Runner' do
  use_frameworks!
  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
end

post_install do |installer|
  project_dir = File.dirname(File.realpath(__FILE__))
  flutter_fw_dir = File.join(project_dir, 'Flutter')
  flutter_header_dir = File.join(flutter_fw_dir, 'Flutter.framework', 'Headers')
  
  # 修复：Xcode 15+ 需要 Pods 目标能直接找到 Flutter.h
  # 创建软链接到 Pods/Headers/Public 目录
  pods_public_headers = File.join(project_dir, 'Pods', 'Headers', 'Public')
  flutter_link_dir = File.join(pods_public_headers, 'Flutter')
  unless File.exist?(flutter_link_dir)
    FileUtils.mkdir_p(flutter_link_dir)
    if File.exist?(flutter_header_dir)
      Dir.glob(File.join(flutter_header_dir, '*')).each do |h|
        FileUtils.ln_s(h, File.join(flutter_link_dir, File.basename(h))) rescue nil
      end
    end
  end
  
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)
    target.build_configurations.each do |config|
      config.build_settings['SWIFT_VERSION'] = '5.0'
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '13.0'
      
      fsp = config.build_settings['FRAMEWORK_SEARCH_PATHS'] || ['$(inherited)']
      fsp = [fsp] unless fsp.is_a?(Array)
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] = (fsp + [flutter_fw_dir, '${PODS_ROOT}/../Flutter']).uniq
      
      hsp = config.build_settings['HEADER_SEARCH_PATHS'] || ['$(inherited)']
      hsp = [hsp] unless hsp.is_a?(Array)
      config.build_settings['HEADER_SEARCH_PATHS'] = (hsp + [flutter_header_dir, '${PODS_ROOT}/Headers/Public']).uniq
    end
  end
end
